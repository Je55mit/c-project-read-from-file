#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <ctype.h>

#define MAX_USERS 100
#define MAX_NAME_LENGTH 50
#define MAX_PHONE_LENGTH 20
#define MAX_POSITIONS 10
#define MAX_POSITION_LENGTH 100

// Structure for a position/job experience
typedef struct {
    char title[MAX_POSITION_LENGTH];
    char duration[MAX_POSITION_LENGTH];
    char company[MAX_POSITION_LENGTH];
} Position;

// Structure for a CV
typedef struct {
    char name[MAX_NAME_LENGTH];
    char surname[MAX_NAME_LENGTH];
    char phone[MAX_PHONE_LENGTH];
    char email[MAX_NAME_LENGTH];
    Position positions[MAX_POSITIONS];
    int position_count;
} CV;

// Global variables
CV users[MAX_USERS];
int user_count = 0;
int current_user = -1;

// Function declarations
void display_main_menu();
void display_user_menu(int user_idx);
void create_cv();
void view_own_cv();
void view_all_cvs();
void search_cvs();
void edit_cv();
void delete_cv();
void clear_screen();
void pause_screen();
void save_cvs_to_file();
void load_cvs_from_file();

// Clear screen function (cross-platform)
void clear_screen() {
    system("cls");
}

// Pause screen
void pause_screen() {
    printf("\nPress Enter to continue...");
    getchar();
}

// Save CVs to file
void save_cvs_to_file() {
    FILE *file = fopen("users.txt", "w");
    if (file == NULL) {
        printf("Error: Could not create data file.\n");
        return;
    }

    fprintf(file, "%d\n", user_count);
    for (int i = 0; i < user_count; i++) {
        fprintf(file, "%s|%s|%s|%s|%d\n", 
                users[i].name, 
                users[i].surname, 
                users[i].phone, 
                users[i].email,
                users[i].position_count);
        
        for (int j = 0; j < users[i].position_count; j++) {
            fprintf(file, "%s|%s|%s\n",
                    users[i].positions[j].title,
                    users[i].positions[j].duration,
                    users[i].positions[j].company);
        }
    }
    fclose(file);
}

// Load CVs from file
void load_cvs_from_file() {
    FILE *file = fopen("users.txt", "r");
    if (file == NULL) {
        return; // File doesn't exist yet
    }

    fscanf(file, "%d\n", &user_count);
    
    for (int i = 0; i < user_count; i++) {
        fscanf(file, "%49[^|]|%49[^|]|%19[^|]|%49[^\n]\n",
               users[i].name,
               users[i].surname,
               users[i].phone,
               users[i].email);
        
        fscanf(file, "%d\n", &users[i].position_count);
        
        for (int j = 0; j < users[i].position_count; j++) {
            fscanf(file, "%99[^|]|%99[^|]|%99[^\n]\n",
                   users[i].positions[j].title,
                   users[i].positions[j].duration,
                   users[i].positions[j].company);
        }
    }
    fclose(file);
}

// Create a new CV
void create_cv() {
    clear_screen();
    printf("========================================\n");
    printf("           CREATE NEW CV\n");
    printf("========================================\n\n");

    if (user_count >= MAX_USERS) {
        printf("Error: Maximum number of users reached.\n");
        pause_screen();
        return;
    }

    CV *new_cv = &users[user_count];

    printf("Enter First Name: ");
    fgets(new_cv->name, MAX_NAME_LENGTH, stdin);
    new_cv->name[strcspn(new_cv->name, "\n")] = 0;

    printf("Enter Surname: ");
    fgets(new_cv->surname, MAX_NAME_LENGTH, stdin);
    new_cv->surname[strcspn(new_cv->surname, "\n")] = 0;

    printf("Enter Phone Number: ");
    fgets(new_cv->phone, MAX_PHONE_LENGTH, stdin);
    new_cv->phone[strcspn(new_cv->phone, "\n")] = 0;

    printf("Enter Email Address: ");
    fgets(new_cv->email, MAX_NAME_LENGTH, stdin);
    new_cv->email[strcspn(new_cv->email, "\n")] = 0;

    new_cv->position_count = 0;

    printf("\nHow many previous positions do you want to add? (0-%d): ", MAX_POSITIONS);
    int pos_count;
    scanf("%d", &pos_count);
    getchar(); // Clear newline

    if (pos_count < 0) pos_count = 0;
    if (pos_count > MAX_POSITIONS) pos_count = MAX_POSITIONS;

    for (int i = 0; i < pos_count; i++) {
        printf("\n--- Position %d ---\n", i + 1);
        
        printf("Job Title: ");
        fgets(new_cv->positions[i].title, MAX_POSITION_LENGTH, stdin);
        new_cv->positions[i].title[strcspn(new_cv->positions[i].title, "\n")] = 0;

        printf("Company: ");
        fgets(new_cv->positions[i].company, MAX_POSITION_LENGTH, stdin);
        new_cv->positions[i].company[strcspn(new_cv->positions[i].company, "\n")] = 0;

        printf("Duration (e.g., 2020-2023): ");
        fgets(new_cv->positions[i].duration, MAX_POSITION_LENGTH, stdin);
        new_cv->positions[i].duration[strcspn(new_cv->positions[i].duration, "\n")] = 0;

        new_cv->position_count++;
    }

    user_count++;
    save_cvs_to_file();

    printf("\n✓ CV created successfully!\n");
    pause_screen();
}

// View own CV
void view_own_cv() {
    if (current_user == -1) {
        clear_screen();
        printf("========================================\n");
        printf("           NO USER SELECTED\n");
        printf("========================================\n");
        printf("Please select a user from the main menu first.\n");
        pause_screen();
        return;
    }

    clear_screen();
    printf("========================================\n");
    printf("              MY CV\n");
    printf("========================================\n\n");

    CV *cv = &users[current_user];
    
    printf("Name: %s %s\n", cv->name, cv->surname);
    printf("Phone: %s\n", cv->phone);
    printf("Email: %s\n\n", cv->email);

    if (cv->position_count > 0) {
        printf("--- WORK EXPERIENCE ---\n");
        for (int i = 0; i < cv->position_count; i++) {
            printf("\n%d. %s\n", i + 1, cv->positions[i].title);
            printf("   Company: %s\n", cv->positions[i].company);
            printf("   Duration: %s\n", cv->positions[i].duration);
        }
    } else {
        printf("No work experience added yet.\n");
    }

    pause_screen();
}

// View all CVs
void view_all_cvs() {
    clear_screen();
    printf("========================================\n");
    printf("          VIEW ALL CVS\n");
    printf("========================================\n\n");

    if (user_count == 0) {
        printf("No CVs available yet.\n");
        pause_screen();
        return;
    }

    for (int i = 0; i < user_count; i++) {
        printf("[%d] %s %s\n", i + 1, users[i].name, users[i].surname);
        printf("    Phone: %s | Email: %s\n", users[i].phone, users[i].email);
        printf("    Positions: %d\n\n", users[i].position_count);
    }

    printf("Enter CV number to view (0 to go back): ");
    int choice;
    scanf("%d", &choice);
    getchar();

    if (choice > 0 && choice <= user_count) {
        clear_screen();
        printf("========================================\n");
        printf("          CV DETAILS\n");
        printf("========================================\n\n");

        CV *cv = &users[choice - 1];
        
        printf("Name: %s %s\n", cv->name, cv->surname);
        printf("Phone: %s\n", cv->phone);
        printf("Email: %s\n\n", cv->email);

        if (cv->position_count > 0) {
            printf("--- WORK EXPERIENCE ---\n");
            for (int i = 0; i < cv->position_count; i++) {
                printf("\n%d. %s\n", i + 1, cv->positions[i].title);
                printf("   Company: %s\n", cv->positions[i].company);
                printf("   Duration: %s\n", cv->positions[i].duration);
            }
        } else {
            printf("No work experience listed.\n");
        }

        pause_screen();
    }
}

// Search CVs by keyword
void search_cvs() {
    clear_screen();
    printf("========================================\n");
    printf("          SEARCH CVS\n");
    printf("========================================\n\n");

    char search_term[MAX_POSITION_LENGTH];
    printf("Enter search keyword: ");
    fgets(search_term, MAX_POSITION_LENGTH, stdin);
    search_term[strcspn(search_term, "\n")] = 0;

    // Convert search term to lowercase for case-insensitive search
    for (int i = 0; search_term[i]; i++) {
        search_term[i] = tolower(search_term[i]);
    }

    printf("\n========================================\n");
    printf("          SEARCH RESULTS\n");
    printf("========================================\n\n");

    int found_count = 0;

    for (int i = 0; i < user_count; i++) {
        int match = 0;

        // Check in name, surname, email
        char lower_name[MAX_NAME_LENGTH], lower_surname[MAX_NAME_LENGTH], lower_email[MAX_NAME_LENGTH];
        
        strcpy(lower_name, users[i].name);
        strcpy(lower_surname, users[i].surname);
        strcpy(lower_email, users[i].email);

        for (int j = 0; lower_name[j]; j++) lower_name[j] = tolower(lower_name[j]);
        for (int j = 0; lower_surname[j]; j++) lower_surname[j] = tolower(lower_surname[j]);
        for (int j = 0; lower_email[j]; j++) lower_email[j] = tolower(lower_email[j]);

        if (strstr(lower_name, search_term) || strstr(lower_surname, search_term) || strstr(lower_email, search_term)) {
            match = 1;
        }

        // Check in positions
        for (int j = 0; j < users[i].position_count; j++) {
            char lower_title[MAX_POSITION_LENGTH], lower_company[MAX_POSITION_LENGTH];
            
            strcpy(lower_title, users[i].positions[j].title);
            strcpy(lower_company, users[i].positions[j].company);

            for (int k = 0; lower_title[k]; k++) lower_title[k] = tolower(lower_title[k]);
            for (int k = 0; lower_company[k]; k++) lower_company[k] = tolower(lower_company[k]);

            if (strstr(lower_title, search_term) || strstr(lower_company, search_term)) {
                match = 1;
                break;
            }
        }

        if (match) {
            printf("[%d] %s %s\n", ++found_count, users[i].name, users[i].surname);
            printf("    Email: %s\n", users[i].email);
            printf("    Positions: %d\n\n", users[i].position_count);
        }
    }

    if (found_count == 0) {
        printf("No CVs found matching '%s'.\n", search_term);
    }

    pause_screen();
}

// Edit CV
void edit_cv() {
    if (current_user == -1) {
        clear_screen();
        printf("========================================\n");
        printf("           NO USER SELECTED\n");
        printf("========================================\n");
        printf("Please select a user from the main menu first.\n");
        pause_screen();
        return;
    }

    clear_screen();
    printf("========================================\n");
    printf("             EDIT MY CV\n");
    printf("========================================\n\n");

    CV *cv = &users[current_user];

    printf("1. Edit Name (current: %s)\n", cv->name);
    printf("2. Edit Surname (current: %s)\n", cv->surname);
    printf("3. Edit Phone (current: %s)\n", cv->phone);
    printf("4. Edit Email (current: %s)\n", cv->email);
    printf("5. Add Position\n");
    printf("6. Remove Position\n");
    printf("0. Back to Menu\n");
    printf("\nSelect option: ");

    int choice;
    scanf("%d", &choice);
    getchar();

    switch (choice) {
        case 1:
            printf("Enter new name: ");
            fgets(cv->name, MAX_NAME_LENGTH, stdin);
            cv->name[strcspn(cv->name, "\n")] = 0;
            break;
        case 2:
            printf("Enter new surname: ");
            fgets(cv->surname, MAX_NAME_LENGTH, stdin);
            cv->surname[strcspn(cv->surname, "\n")] = 0;
            break;
        case 3:
            printf("Enter new phone: ");
            fgets(cv->phone, MAX_PHONE_LENGTH, stdin);
            cv->phone[strcspn(cv->phone, "\n")] = 0;
            break;
        case 4:
            printf("Enter new email: ");
            fgets(cv->email, MAX_NAME_LENGTH, stdin);
            cv->email[strcspn(cv->email, "\n")] = 0;
            break;
        case 5:
            if (cv->position_count < MAX_POSITIONS) {
                printf("Job Title: ");
                fgets(cv->positions[cv->position_count].title, MAX_POSITION_LENGTH, stdin);
                cv->positions[cv->position_count].title[strcspn(cv->positions[cv->position_count].title, "\n")] = 0;

                printf("Company: ");
                fgets(cv->positions[cv->position_count].company, MAX_POSITION_LENGTH, stdin);
                cv->positions[cv->position_count].company[strcspn(cv->positions[cv->position_count].company, "\n")] = 0;

                printf("Duration: ");
                fgets(cv->positions[cv->position_count].duration, MAX_POSITION_LENGTH, stdin);
                cv->positions[cv->position_count].duration[strcspn(cv->positions[cv->position_count].duration, "\n")] = 0;

                cv->position_count++;
                printf("✓ Position added successfully!\n");
            } else {
                printf("Maximum positions reached.\n");
            }
            break;
        case 6:
            if (cv->position_count > 0) {
                printf("Positions:\n");
                for (int i = 0; i < cv->position_count; i++) {
                    printf("%d. %s at %s\n", i + 1, cv->positions[i].title, cv->positions[i].company);
                }
                printf("Select position to remove (1-%d): ", cv->position_count);
                int pos;
                scanf("%d", &pos);
                getchar();

                if (pos > 0 && pos <= cv->position_count) {
                    for (int i = pos - 1; i < cv->position_count - 1; i++) {
                        cv->positions[i] = cv->positions[i + 1];
                    }
                    cv->position_count--;
                    printf("✓ Position removed successfully!\n");
                }
            } else {
                printf("No positions to remove.\n");
            }
            break;
        case 0:
            return;
        default:
            printf("Invalid option.\n");
    }

    save_cvs_to_file();
    pause_screen();
}

// Delete CV
void delete_cv() {
    if (current_user == -1) {
        clear_screen();
        printf("========================================\n");
        printf("           NO USER SELECTED\n");
        printf("========================================\n");
        printf("Please select a user from the main menu first.\n");
        pause_screen();
        return;
    }

    clear_screen();
    printf("========================================\n");
    printf("            DELETE CV\n");
    printf("========================================\n\n");

    printf("Are you sure you want to delete your CV? (y/n): ");
    char confirm;
    scanf("%c", &confirm);
    getchar();

    if (confirm == 'y' || confirm == 'Y') {
        for (int i = current_user; i < user_count - 1; i++) {
            users[i] = users[i + 1];
        }
        user_count--;
        current_user = -1;
        save_cvs_to_file();
        printf("✓ CV deleted successfully!\n");
    } else {
        printf("Deletion cancelled.\n");
    }

    pause_screen();
}

// Display user menu
void display_user_menu(int user_idx) {
    current_user = user_idx;

    while (1) {
        clear_screen();
        printf("========================================\n");
        printf("  WELCOME, %s %s\n", users[user_idx].name, users[user_idx].surname);
        printf("========================================\n\n");
        printf("1. View My CV\n");
        printf("2. Edit My CV\n");
        printf("3. Delete My CV\n");
        printf("4. View Other CVs\n");
        printf("5. Search CVs\n");
        printf("0. Back to Main Menu\n");
        printf("\nSelect option: ");

        int choice;
        scanf("%d", &choice);
        getchar();

        switch (choice) {
            case 1:
                view_own_cv();
                break;
            case 2:
                edit_cv();
                break;
            case 3:
                delete_cv();
                if (current_user == -1) return;
                break;
            case 4:
                view_all_cvs();
                break;
            case 5:
                search_cvs();
                break;
            case 0:
                current_user = -1;
                return;
            default:
                printf("Invalid option. Please try again.\n");
                pause_screen();
        }
    }
}

// Display main menu
void display_main_menu() {
    while (1) {
        clear_screen();
        printf("========================================\n");
        printf("    JOB SOCIAL NETWORK SYSTEM\n");
        printf("========================================\n\n");
        printf("1. Create New CV\n");
        printf("2. Select Existing CV / Login\n");
        printf("3. View All CVs\n");
        printf("4. Search CVs\n");
        printf("0. Exit Application\n");
        printf("\nSelect option: ");

        int choice;
        scanf("%d", &choice);
        getchar();

        switch (choice) {
            case 1:
                create_cv();
                break;
            case 2: {
                if (user_count == 0) {
                    clear_screen();
                    printf("========================================\n");
                    printf("           NO CVS AVAILABLE\n");
                    printf("========================================\n");
                    printf("Please create a CV first.\n");
                    pause_screen();
                    break;
                }

                clear_screen();
                printf("========================================\n");
                printf("          SELECT USER\n");
                printf("========================================\n\n");

                for (int i = 0; i < user_count; i++) {
                    printf("[%d] %s %s\n", i + 1, users[i].name, users[i].surname);
                }

                printf("\nSelect user (0 to cancel): ");
                int user_choice;
                scanf("%d", &user_choice);
                getchar();

                if (user_choice > 0 && user_choice <= user_count) {
                    display_user_menu(user_choice - 1);
                }
                break;
            }
            case 3:
                view_all_cvs();
                break;
            case 4:
                search_cvs();
                break;
            case 0:
                clear_screen();
                printf("========================================\n");
                printf("  Thank you for using our system!\n");
                printf("========================================\n");
                exit(0);
            default:
                printf("Invalid option. Please try again.\n");
                pause_screen();
        }
    }
}

int main() {
    load_cvs_from_file();
    display_main_menu();
    return 0;
}
